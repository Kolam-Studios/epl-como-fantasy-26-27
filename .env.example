# Postgres connection string. Neon/Supabase free tier, or a self-hosted container.
# Neon example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Commissioner gate. Only a client holding this token may POST draft results.
# Everyone else gets the read-only live view. Set to any random string.
COMMISSIONER_TOKEN=change-me
